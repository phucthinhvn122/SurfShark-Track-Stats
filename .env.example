# ---------- Database (Supabase) ----------
# For Render/API/worker, prefer Supabase's IPv4-compatible session pooler.
# Use Supabase Dashboard -> Project Settings -> Database -> Connection pooling -> Session mode.
DATABASE_URL="postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

# Prisma migrations can use the true direct URL only from IPv6-capable networks.
# If db.PROJECT_REF.supabase.co:5432 gives P1001, use the same session-pooler URL as DATABASE_URL.
DIRECT_URL="postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

# Serverless-only alternative:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ---------- Redis (Upstash) ----------
REDIS_URL="rediss://default:PASSWORD@HOST:6379"

# ---------- API ----------
PORT=3001
LOG_LEVEL=info
JWT_SECRET="change-me-min-32-chars-long-secret-value"
SESSION_ENC_KEY="change-me-32-byte-aes-gcm-key-base64"
WEB_ORIGIN="https://surfshark-activate.vercel.app"

# ---------- Telegram worker ----------
TG_API_ID="1234567"
TG_API_HASH="your_api_hash_from_my.telegram.org"
# Single session (back-compat):
TG_SESSION="paste_decrypted_string_session_here"
# OR multiple sessions for the pool (comma-separated, encrypted or plain):
TG_SESSIONS=""
BOT_USERNAME="@SurfsharkBot"
WORKER_CONCURRENCY=5

# ---------- Surfshark device-code source (for POST /key-redeem) ----------
# Set AT LEAST ONE of the three strategies below. The first one that returns a
# value wins; others are skipped.
# 1) Path to a file written by the Surfshark app (raw 6-char string or JSON):
SURFSHARK_DEVICE_CODE_FILE=""
# 2) HTTP endpoint that returns the device code (JSON {"deviceCode":"..."} or text):
SURFSHARK_DEVICE_CODE_URL=""
# 3) Shell command whose stdout is the device code:
SURFSHARK_DEVICE_CODE_CLI=""

# ---------- Observability (optional) ----------
SENTRY_DSN=""
NODE_ENV="production"

# ---------- Frontend (apps/web/.env) ----------
NEXT_PUBLIC_API_URL="https://api.surfshark-activate.app"
