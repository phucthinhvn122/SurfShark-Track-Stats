{
  "name": "surfshark-platform",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed.ts",
    "db:generate": "prisma generate",
    "railway:build:api": "pnpm exec prisma generate && pnpm --filter @surfshark/api build",
    "railway:start:api": "pnpm --filter @surfshark/api start",
    "railway:build:worker": "pnpm exec prisma generate && pnpm --filter @surfshark/telegram-worker build",
    "railway:start:worker": "pnpm --filter @surfshark/telegram-worker start:prod",
    "render:build": "pnpm install --frozen-lockfile --prod=false && pnpm exec prisma generate && pnpm build",
    "render:start": "node scripts/start-combined.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "argon2": "^0.40.1",
    "prisma": "^5.14.0"
  }
}
